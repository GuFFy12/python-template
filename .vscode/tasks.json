{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run",
      "type": "shell",
      "command": "uv run python src/python_template/main.py",
      "problemMatcher": []
    },
    {
      "label": "Run post-create script",
      "type": "shell",
      "command": ".devcontainer/post-create.sh",
      "problemMatcher": []
    },
    {
      "label": "Run pre-commit for all files",
      "type": "shell",
      "command": "uv run pre-commit run --all-files",
      "problemMatcher": []
    },
    {
      "label": "Run mypy for all files",
      "type": "shell",
      "command": "uv run mypy .",
      "problemMatcher": ["$mypy"]
    },
    {
      "label": "Secrets: Update & Audit",
      "type": "shell",
      "command": "uv run detect-secrets scan --baseline .secrets.baseline && uv run detect-secrets audit .secrets.baseline",
      "presentation": { "focus": true },
      "problemMatcher": []
    }
  ]
}
