{
  "extends": ["config:best-practices"],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Disable digest pinning for DevContainer",
      "matchFileNames": [".devcontainer/**"],
      "pinDigests": false
    }
  ]
}
